      "message": "@ed@tanous.net\n\nFirst of all, this is a fairly long report, and I want to mention up front that\nthe shell script used for the testing was generated with the help of an LLM.\n\nPer your suggestion, I ran a test by creating 1,000 HwmonTempSensor instances\nusing a single TMP75 sensor.\n\nSince Entity Manager only creates a single device when the configuration points\nto the same bus and address, I temporarily modified the HwmonTempMain.cpp code to\nforce the creation of 1,000 duplicated sensor instances.\n\n```\ndiff --git a/src/hwmon-temp/HwmonTempMain.cpp b/src/hwmon-temp/HwmonTempMain.cpp\nindex e9ddb5c7a..5a9cbd2dd 100644\n--- a/src/hwmon-temp/HwmonTempMain.cpp\n+++ b/src/hwmon-temp/HwmonTempMain.cpp\n@@ -465,9 +466,27 @@ void createSensors(\n                         sensor \u003d std::make_shared\u003cHwmonTempSensor\u003e(\n                             *hwmonFile, sensorType, objectServer,\n                             dbusConnection, io, sensorName,\n-                            std::move(sensorThresholds), thisSensorParameters,\n-                            pollRate, interfacePath, readState, i2cDev);\n+                            std::vector\u003cthresholds::Threshold\u003e(\n+                            sensorThresholds),\n+                            thisSensorParameters, pollRate, interfacePath,\n+                            readState, i2cDev);\n                         sensor-\u003esetupRead();\n+\n+                        constexpr int kStressCount \u003d 1000;\n+                        for (int idx \u003d 1; idx \u003c kStressCount; ++idx)\n+                        {\n+                            std::string stressName \u003d\n+                                sensorName + \"_\" + std::to_string(idx);\n+                            auto\u0026 s \u003d sensors[stressName];\n+                            s \u003d std::make_shared\u003cHwmonTempSensor\u003e(\n+                                *hwmonFile, sensorType, objectServer,\n+                                dbusConnection, io, stressName,\n+                                std::vector\u003cthresholds::Threshold\u003e(\n+                                    sensorThresholds),\n+                                thisSensorParameters, pollRate, interfacePath,\n+                                readState, i2cDev);\n+                            s-\u003esetupRead();\n+                        }\n                     }\n                 }\n                 hwmonName.erase(\n```\n\nThe script below was used for the measurements.\n\n```\n#!/bin/sh\n# bmc-iowait-probe.sh\n#\n# Collect dbus-sensors / io_uring / iowait state on a BMC for A/B\n# comparison (e.g., before/after the BOOST_ASIO_DISABLE_EPOLL change).\n# Run on the BMC. No deps beyond busybox.\n#\n# Usage:\n#   bmc-iowait-probe.sh [LABEL] [WINDOW_SEC] [LATENCY_PROBES]\n#\n# Example:\n#   ./bmc-iowait-probe.sh BEFORE 60 \u003e /tmp/before.txt\n#   # ... reflash with patched build ...\n#   ./bmc-iowait-probe.sh AFTER 60  \u003e /tmp/after.txt\n#   diff /tmp/before.txt /tmp/after.txt\n#\n# Captures:\n#   - per-service sensor instance count (D-Bus)\n#   - daemon wchan / syscall (where they\u0027re sleeping -\u003e which reactor is active)\n#   - cpufreq state (governor + cur_freq) — verifies/rules out cpufreq theory\n#   - /proc/stat cpu line deltas (user/sys/idle/iowait per second)\n#   - intr / ctxt rate\n#   - per-IRQ deltas for i2c / aspeed-i2c (which buses are hot, how hot)\n#   - PropertiesChanged signal rate on /sensors paths over the window\n#     (independent confirmation that the same number of sensor updates\n#      are being delivered)\n#   - hwmontempsensor io_uring fdinfo (SQE/CQE counts)\n#   - sensor value sanity check (a few sensors\u0027 D-Bus Value)\n#   - D-Bus get-property latency distribution\n#   - top snapshot\n\nLABEL\u003d\"${1:-snapshot}\"\nWINDOW\u003d\"${2:-5}\"\nLATENCY_PROBES\u003d\"${3:-50}\"\nTMP\u003d\"${TMPDIR:-/tmp}\"\n\necho \"\u003d\u003d\u003d\u003d\u003d ${LABEL} (window\u003d${WINDOW}s) $(date) \u003d\u003d\u003d\u003d\u003d\"\necho\n\n#-----------------------------------------------------------------------\n# 1. D-Bus sensor instance counts\n#-----------------------------------------------------------------------\necho \"--- sensor instance counts ---\"\nfor svc in HwmonTempSensor PSUSensor ADCSensor IpmbSensor IntelCPUSensor \\\n           MCUTempSensor SmbpbiSensor FanSensor ExternalSensor \\\n           ExitAirTempSensor IntrusionSensor; do\n    count\u003d$(busctl tree \"xyz.openbmc_project.${svc}\" 2\u003e/dev/null \\\n            | grep -c \"/sensors/\")\n    [ \"$count\" -gt 0 ] \u0026\u0026 printf \"  %-22s %d\\n\" \"$svc\" \"$count\"\ndone\necho\n\n#-----------------------------------------------------------------------\n# 2. Daemon wchan (where each daemon is parked)\n#    wchan tells us which reactor is active:\n#      do_epoll_wait    -\u003e epoll path (DISABLE_EPOLL not set)\n#      io_cqring_wait   -\u003e io_uring path (DISABLE_EPOLL set)\n#-----------------------------------------------------------------------\necho \"--- daemon wchan / syscall ---\"\nfor n in hwmontempsensor psusensor adcsensor fansensor ipmbsensor \\\n         mcutempsensor smbpbisensor intelcpusensor entity-manager \\\n         swampd phosphor-regulators bmcweb pldmd mctpd; do\n    p\u003d$(pidof \"$n\" 2\u003e/dev/null)\n    [ -z \"$p\" ] \u0026\u0026 continue\n    w\u003d$(cat \"/proc/$p/wchan\" 2\u003e/dev/null)\n    sc\u003d$(awk \u0027{print $1}\u0027 \"/proc/$p/syscall\" 2\u003e/dev/null)\n    printf \"  %-22s pid\u003d%-6s wchan\u003d%-20s syscall\u003d%s\\n\" \"$n\" \"$p\" \"$w\" \"$sc\"\ndone\necho \"  (syscall: epoll_wait\u003d232/252, io_uring_enter\u003d426/427 depending on arch)\"\necho\n\n#-----------------------------------------------------------------------\n# 3. cpufreq state — to verify or rule out cpufreq\u0027s role in CPU% diff\n#-----------------------------------------------------------------------\necho \"--- cpufreq state ---\"\ncpufreq_seen\u003d0\nfor f in /sys/devices/system/cpu/cpu[0-9]*/cpufreq/cur_freq; do\n    [ -r \"$f\" ] || continue\n    cpu_id\u003d$(echo \"$f\" | sed \u0027s|.*/cpu\\([0-9]*\\)/.*|\\1|\u0027)\n    freq_khz\u003d$(cat \"$f\" 2\u003e/dev/null)\n    gov\u003d$(cat \"$(dirname \"$f\")/scaling_governor\" 2\u003e/dev/null)\n    cur\u003d$(cat \"$(dirname \"$f\")/scaling_cur_freq\" 2\u003e/dev/null)\n    printf \"  cpu%s cur\u003d%s kHz scaling_cur\u003d%s governor\u003d%s\\n\" \\\n        \"$cpu_id\" \"$freq_khz\" \"$cur\" \"$gov\"\n    cpufreq_seen\u003d1\ndone\n[ \"$cpufreq_seen\" \u003d \"0\" ] \u0026\u0026 \\\n    echo \"  cpufreq scaling not exposed (likely fixed-frequency BMC)\"\necho\n\n#-----------------------------------------------------------------------\n# 4. Start D-Bus PropertiesChanged signal monitor in background.\n#    Runs concurrently with the /proc/stat sample window so we can count\n#    actual sensor update signals delivered during the same interval.\n#    Path / Member appear on the same indented line in busctl monitor\u0027s\n#    text format, so a single awk match counts each signal cleanly.\n#-----------------------------------------------------------------------\nSIGFILE\u003d\"${TMP}/probe_signals_$$\"\nrm -f \"$SIGFILE\"\nbusctl monitor \u003e \"$SIGFILE\" 2\u003e/dev/null \u0026\nMON_PID\u003d$!\n\n#-----------------------------------------------------------------------\n# 5. Sample /proc/stat counters before/after window\n#-----------------------------------------------------------------------\nA_CPU\u003d$(awk \u0027/^cpu / {print}\u0027 /proc/stat)\nA_INTR\u003d$(awk \u0027/^intr / {print $2}\u0027 /proc/stat)\nA_CTXT\u003d$(awk \u0027/^ctxt / {print $2}\u0027 /proc/stat)\ngrep -E \"i2c|aspeed\" /proc/interrupts \u003e \"${TMP}/probe_irq_a\" 2\u003e/dev/null\n\nsleep \"$WINDOW\"\n\nB_CPU\u003d$(awk \u0027/^cpu / {print}\u0027 /proc/stat)\nB_INTR\u003d$(awk \u0027/^intr / {print $2}\u0027 /proc/stat)\nB_CTXT\u003d$(awk \u0027/^ctxt / {print $2}\u0027 /proc/stat)\ngrep -E \"i2c|aspeed\" /proc/interrupts \u003e \"${TMP}/probe_irq_b\" 2\u003e/dev/null\n\n# stop signal monitor\nkill \"$MON_PID\" 2\u003e/dev/null\nwait \"$MON_PID\" 2\u003e/dev/null\n\n#-----------------------------------------------------------------------\n# 6. /proc/stat cpu deltas — the iowait signal\n#-----------------------------------------------------------------------\necho \"--- /proc/stat cpu deltas (${WINDOW}s) ---\"\necho \"  before: $A_CPU\"\necho \"  after : $B_CPU\"\necho \"$A_CPU :: $B_CPU\" | awk -v w\u003d\"$WINDOW\" \u0027\n{\n    n \u003d split($0, parts, \" :: \")\n    split(parts[1], a, \" \")\n    split(parts[2], b, \" \")\n    printf \"  per second: user\u003d%.1f sys\u003d%.1f idle\u003d%.1f iowait\u003d%.1f irq\u003d%.1f softirq\u003d%.1f\\n\",\n        (b[2]-a[2])/w, (b[4]-a[4])/w, (b[5]-a[5])/w,\n        (b[6]-a[6])/w, (b[7]-a[7])/w, (b[8]-a[8])/w\n}\u0027\necho\necho \"  intr/s : $(( (B_INTR - A_INTR) / WINDOW ))\"\necho \"  ctxt/s : $(( (B_CTXT - A_CTXT) / WINDOW ))\"\necho\n\n#-----------------------------------------------------------------------\n# 7. Per-IRQ delta for i2c / aspeed-i2c\n#-----------------------------------------------------------------------\necho \"--- I2C IRQ deltas ---\"\nawk -v w\u003d\"$WINDOW\" \u0027\nNR\u003d\u003dFNR { a[$1] \u003d $2 + 0; for (i \u003d 3; i \u003c\u003d NF; i++) if ($i ~ /^[0-9]+$/) a[$1] +\u003d $i; tag[$1] \u003d $NF; next }\n{\n    sum \u003d $2 + 0\n    for (i \u003d 3; i \u003c\u003d NF; i++) if ($i ~ /^[0-9]+$/) sum +\u003d $i\n    if ($1 in a) {\n        delta \u003d sum - a[$1]\n        if (delta \u003e 0)\n            printf \"  IRQ %-4s %-25s +%d total over %ds (%.0f/s)\\n\", $1, tag[$1], delta, w, delta/w\n    }\n}\u0027 \"${TMP}/probe_irq_a\" \"${TMP}/probe_irq_b\"\necho\n\n#-----------------------------------------------------------------------\n# 8. PropertiesChanged signal rate (collected during the window)\n#-----------------------------------------------------------------------\necho \"--- D-Bus PropertiesChanged on /sensors (${WINDOW}s window) ---\"\nif [ -s \"$SIGFILE\" ]; then\n    # busctl monitor format: each signal has one line with both\n    # \"Path\u003d...\" and \"Member\u003d...\" on it (Sender ... Path ... Member ...).\n    SIGCOUNT\u003d$(awk \u0027\n        /Path\u003d\\/xyz\\/openbmc_project\\/sensors/ \u0026\u0026\n        /Member\u003dPropertiesChanged/ { c++ }\n        END { print c+0 }\n    \u0027 \"$SIGFILE\")\n    SIGTOTAL\u003d$(awk \u0027/Member\u003dPropertiesChanged/ { c++ } END { print c+0 }\u0027 \"$SIGFILE\")\n    printf \"  signals on /sensors: %d  (%d/s)\\n\" \\\n        \"$SIGCOUNT\" \"$(( SIGCOUNT / WINDOW ))\"\n    printf \"  all PropertiesChanged: %d  (%d/s)\\n\" \\\n        \"$SIGTOTAL\" \"$(( SIGTOTAL / WINDOW ))\"\nelse\n    echo \"  (no busctl monitor output captured)\"\nfi\nrm -f \"$SIGFILE\"\necho\n\n#-----------------------------------------------------------------------\n# 9. hwmontempsensor io_uring state (most directly affected daemon)\n#-----------------------------------------------------------------------\nP\u003d$(pidof hwmontempsensor 2\u003e/dev/null)\nif [ -n \"$P\" ]; then\n    echo \"--- hwmontempsensor pid\u003d$P ---\"\n    grep -E \"^(VmRSS|VmSize|Threads):\" \"/proc/$P/status\"\n    echo \"  wchan  : $(cat /proc/$P/wchan 2\u003e/dev/null)\"\n    echo \"  syscall: $(cat /proc/$P/syscall 2\u003e/dev/null)\"\n\n    echo \"  anon fds:\"\n    ls -l \"/proc/$P/fd/\" 2\u003e/dev/null | awk \u0027/anon_inode/ {\n        sub(/.* -\u003e /, \"\")\n        print \"    \" $0\n    }\u0027 | sort -u\n\n    IO_FD\u003d\"\"\n    for fd in \"/proc/$P/fd/\"*; do\n        num\u003d\"${fd##*/}\"\n        case \"$num\" in *[!0-9]*) continue ;; esac\n        target\u003d$(readlink \"$fd\" 2\u003e/dev/null)\n        case \"$target\" in\n            *io_uring*) IO_FD\u003d\"$num\"; break ;;\n        esac\n    done\n    if [ -n \"$IO_FD\" ]; then\n        echo \"  io_uring fdinfo (fd $IO_FD):\"\n        sed -n \u00271,12p\u0027 \"/proc/$P/fdinfo/$IO_FD\" 2\u003e/dev/null | sed \u0027s/^/    /\u0027\n    fi\nfi\necho\n\n#-----------------------------------------------------------------------\n# 10. Sensor value sanity check — pick a few HwmonTempSensor paths and\n#     read their current D-Bus Value. Verifies sensor reading actually\n#     works under the build being measured.\n#-----------------------------------------------------------------------\necho \"--- sensor value sanity (first 5 HwmonTempSensor paths) ---\"\nbusctl tree xyz.openbmc_project.HwmonTempSensor 2\u003e/dev/null \\\n    | grep -oE \u0027/xyz/openbmc_project/sensors/temperature/[A-Za-z0-9_/-]+\u0027 \\\n    | awk \u0027NR\u003c\u003d5\u0027 \\\n    | while read sensor_path; do\n        v\u003d$(busctl get-property xyz.openbmc_project.HwmonTempSensor \\\n                \"$sensor_path\" \\\n                xyz.openbmc_project.Sensor.Value Value 2\u003e/dev/null)\n        printf \"  %s \u003d %s\\n\" \"$sensor_path\" \"$v\"\n    done\necho\n\n#-----------------------------------------------------------------------\n# 11. D-Bus get-property latency distribution\n#-----------------------------------------------------------------------\nPROBE_PATH\u003d$(busctl tree xyz.openbmc_project.HwmonTempSensor 2\u003e/dev/null \\\n             | grep -oE \u0027/xyz/openbmc_project/sensors/temperature/[A-Za-z0-9_/-]+\u0027 \\\n             | awk \u0027NR\u003d\u003d1\u0027)\nif [ -n \"$PROBE_PATH\" ]; then\n    echo \"--- D-Bus get-property latency (${LATENCY_PROBES} probes) ---\"\n    LATFILE\u003d\"${TMP}/probe_lat_$$\"\n    : \u003e \"$LATFILE\"\n    i\u003d0\n    while [ \"$i\" -lt \"$LATENCY_PROBES\" ]; do\n        T0\u003d$(awk \u0027{printf \"%d\", $1*1000000}\u0027 /proc/uptime)\n        busctl get-property xyz.openbmc_project.HwmonTempSensor \\\n            \"$PROBE_PATH\" \\\n            xyz.openbmc_project.Sensor.Value Value \u003e /dev/null 2\u003e\u00261\n        T1\u003d$(awk \u0027{printf \"%d\", $1*1000000}\u0027 /proc/uptime)\n        echo $((T1 - T0)) \u003e\u003e \"$LATFILE\"\n        i\u003d$((i+1))\n    done\n    sort -n \"$LATFILE\" \u003e \"${LATFILE}.sorted\"\n    N\u003d$(wc -l \u003c \"${LATFILE}.sorted\" | tr -d \u0027 \u0027)\n    if [ \"$N\" -gt 0 ]; then\n        P50\u003d$(sed -n \"$(( N / 2 ))p\" \"${LATFILE}.sorted\")\n        P90\u003d$(sed -n \"$(( (N * 9 + 9) / 10 ))p\" \"${LATFILE}.sorted\")\n        P99\u003d$(sed -n \"$(( (N * 99 + 99) / 100 ))p\" \"${LATFILE}.sorted\")\n        AVG\u003d$(awk \u0027{ s +\u003d $1 } END { if (NR\u003e0) printf \"%d\", s/NR }\u0027 \"$LATFILE\")\n        MIN\u003d$(sed -n \u00271p\u0027 \"${LATFILE}.sorted\")\n        MAX\u003d$(sed -n \"${N}p\" \"${LATFILE}.sorted\")\n        printf \"  path: %s\\n\" \"$PROBE_PATH\"\n        printf \"  microseconds: count\u003d%d min\u003d%d avg\u003d%d p50\u003d%d p90\u003d%d p99\u003d%d max\u003d%d\\n\" \\\n            \"$N\" \"$MIN\" \"$AVG\" \"$P50\" \"$P90\" \"$P99\" \"$MAX\"\n    fi\n    rm -f \"$LATFILE\" \"${LATFILE}.sorted\"\nfi\necho\n\n#-----------------------------------------------------------------------\n# 12. top snapshot for context\n#-----------------------------------------------------------------------\necho \"--- top snapshot ---\"\ntop -bn1 2\u003e/dev/null | sed -n \u00271,8p\u0027\necho\n\necho \"\u003d\u003d\u003d\u003d\u003d END ${LABEL} \u003d\u003d\u003d\u003d\u003d\"\n```\n\nTo be continued in the next comment.",
